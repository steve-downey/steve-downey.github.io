## -*- coding: utf-8 -*-
<%inherit file="base.tmpl"/>
<%namespace name="archive_nav" file="archive_navigation_helper.tmpl" import="*"/>
<%namespace name="feeds_translations" file="feeds_translations_helper.tmpl" import="*"/>

<%block name="extra_head">
    ${feeds_translations.head(kind=kind, rss_override=False)}
</%block>

<%block name="page_header">
<h1 class="text-4xl font-bold">${blog_title|h}</h1>
<p class="mt-2 text-lg text-indigo-200">${title|h}</p>
</%block>

<%block name="content">
<article class="listpage">
    ${archive_nav.archive_navigation()}
    ${feeds_translations.translation_link(kind)}
    %if items:
    <ul class="not-prose space-y-2">
    % for text, link, count in items:
        <li>
            <a href="${link}" class="text-indigo-600 hover:underline">${text|h}</a>
            % if count:
                <span class="text-sm text-gray-500">(${count})</span>
            % endif
        </li>
    % endfor
    </ul>
    %else:
    <p class="text-gray-500">${messages("Nothing found.")}</p>
    %endif
</article>
</%block>
