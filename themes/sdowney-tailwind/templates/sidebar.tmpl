## -*- coding: utf-8 -*-
<%
    recent_posts = all_posts[:10]
%>
<aside class="not-prose mt-10 lg:mt-0 lg:w-64 lg:shrink-0 lg:sticky lg:top-6 lg:self-start space-y-8">

    <section>
        <button id="theme-toggle"
                class="flex items-center gap-2 text-sm text-gray-500 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 transition-colors"
                aria-label="Toggle dark mode">
            <i class="fa-solid fa-circle-half-stroke"></i>
            <span>Toggle theme</span>
        </button>
    </section>

    <section>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Recent Posts</h2>
        <ul class="space-y-3">
        % for post in recent_posts:
            <li>
                <a href="${post.permalink()}"
                   class="text-sm text-gray-700 hover:text-indigo-600 transition-colors leading-snug block">${post.title()|h}</a>
                <time class="text-xs text-gray-400"
                      datetime="${post.formatted_date('webiso')}">${post.formatted_date(date_format)|h}</time>
            </li>
        % endfor
        </ul>
    </section>

    <section>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Archives</h2>
        <a href="${_link('archive', None)}"
           class="text-sm text-indigo-600 hover:text-indigo-800 transition-colors">All posts &rarr;</a>
    </section>

    <section>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Tags</h2>
        <a href="${_link('tag_index', None)}"
           class="text-sm text-indigo-600 hover:text-indigo-800 transition-colors">Browse tags &rarr;</a>
    </section>

    <section>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Feeds</h2>
        <ul class="space-y-1">
            <li><a href="/feed.atom" class="text-sm text-indigo-600 hover:text-indigo-800 transition-colors">Atom</a></li>
            <li><a href="/rss.xml" class="text-sm text-indigo-600 hover:text-indigo-800 transition-colors">RSS</a></li>
        </ul>
    </section>

</aside>
